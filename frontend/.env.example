# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Browser-exposed (safe): RLS enforces per-user isolation.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only secrets. NEVER expose to the browser.
GEMINI_API_KEY=your-gemini-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
# Set true ONLY if your Alpha Vantage key is premium — enables single-request
# batched quotes (REALTIME_BULK_QUOTES). Free-tier keys return sample data from
# that endpoint, so leave unset/false to use accurate per-symbol quotes.
ALPHA_VANTAGE_PREMIUM=false
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
CRON_SECRET=your-cron-secret
KITE_API_KEY=your-kite-api-key
KITE_ACCESS_TOKEN=your-kite-access-token
KITE_LIVE_TRADING=false
